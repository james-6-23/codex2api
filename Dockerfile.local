FROM golang:1.23-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o codex2api .

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /root/
COPY --from=builder /app/codex2api .
COPY --from=builder /app/frontend/dist ./frontend/dist
EXPOSE 8080
CMD ["./codex2api"]
